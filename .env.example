# MoeNet Core Environment Variables
# Copy this file to .env and fill in the values

# =============================================================================
# Database
# =============================================================================
DB_PASSWORD=your_secure_password_here

# =============================================================================
# Authentication
# =============================================================================
JWT_SECRET=your_jwt_secret_here
AGENT_API_KEY=your_agent_api_key_here
API_TOKEN=your_api_token_here

# =============================================================================
# Telegram Bot
# =============================================================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_ADMIN_USERNAME=your_telegram_username
TELEGRAM_ADMIN_CHAT_ID=your_telegram_chat_id
TELEGRAM_CONTACT=@heicha
LOCAL_ASN=4242420998

# Webhook (required for production)
WEBHOOK_DOMAIN=bot.example.com
WEBHOOK_SECRET=your_webhook_secret
WEBHOOK_PORT=8443

# Redis session persistence (optional, uses in-memory if not set)
# REDIS_URL=redis://moenet-redis:6379

# Rate limiting (optional)
# RATE_LIMIT_MAX=20
# RATE_LIMIT_WINDOW_MS=60000

# =============================================================================
# Agent Configuration (for distributed tools)
# Format: JSON object mapping node IDs to host addresses
# =============================================================================
AGENT_HOSTS='{"jp-rr":"10.0.0.1","hk-edge":"10.0.0.2"}'
AGENT_PORT=8080
AGENT_TOKEN=your_agent_token

# =============================================================================
# Node Names (display names for inline keyboards)
# Format: JSON object mapping node IDs to display names
# =============================================================================
NODE_NAMES='{"jp-rr":"JP Tokyo","hk-edge":"HK Edge"}'

# =============================================================================
# Email Service (Mailgun)
# =============================================================================
MAILGUN_API_KEY=your_mailgun_api_key
MAILGUN_DOMAIN=dn42.moenet.work
MAILGUN_FROM=DN42 Bot <bot@dn42.moenet.work>

# =============================================================================
# Control Plane / Bootstrap
# =============================================================================
CORE_URL=https://api.moenet.work

# Binary download URLs (optional, defaults to GitHub releases)
# AGENT_DOWNLOAD_URL=https://github.com/heichaowo/moenet-agent/releases/latest/download/moenet-agent-linux-amd64
# BIRD_DOWNLOAD_URL=https://github.com/heichaowo/dn42-binaries/releases/latest/download/bird
# BIRDC_DOWNLOAD_URL=https://github.com/heichaowo/dn42-binaries/releases/latest/download/birdc

# =============================================================================
# Monitoring (Grafana/Prometheus)
# =============================================================================
GRAFANA_PASSWORD=  # Required - Grafana admin password


