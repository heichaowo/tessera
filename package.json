{
  "name": "moenet-core",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:api": "bun run --filter @moenet/api dev",
    "dev:web": "bun run --filter @moenet/web dev",
